{
  "name": "@hydra-acp/cli",
  "version": "0.1.114",
  "description": "Multi-client ACP session daemon: spawn agents, attach over WSS, multiplex sessions across editors.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/smagnuso/hydra-acp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smagnuso/hydra-acp.git"
  },
  "bugs": {
    "url": "https://github.com/smagnuso/hydra-acp/issues"
  },
  "keywords": [
    "acp",
    "agent-client-protocol",
    "claude",
    "codex",
    "gemini",
    "daemon",
    "websocket"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "hydra-acp": "dist/cli.js",
    "hydra": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/websocket": "^11.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chalk": "^4.1.2",
    "cli-highlight": "^2.1.11",
    "fastify": "^5.0.0",
    "nanoid": "^5.0.0",
    "pino": "^9.14.0",
    "pino-roll": "^4.0.0",
    "string-width": "^8.2.1",
    "strip-ansi": "^7.2.0",
    "terminal-kit": "^3.1.2",
    "undici": "^8.5.0",
    "update-notifier": "^7.3.1",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/terminal-kit": "^2.5.7",
    "@types/update-notifier": "^6.0.8",
    "@types/ws": "^8.5.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
